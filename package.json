{
  "name": "cedx-tiny-kit",
  "version": "1.0.0",
  "private": true,
  "description": "CEDX Real Estate Agent Fleet — multi-agent governed pipeline (Property Appraisals)",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "demo": "tsx src/pipeline.ts",
    "verify": "python3 verify_audit.py --audit out/audit.json --transcripts transcripts --schema audit.schema.json",
    "trace": "tsx src/cli/trace.ts",
    "replay": "tsx src/cli/replay.ts",
    "eval": "tsx src/cli/eval.ts",
    "probe-approval": "tsx src/cli/probe-approval.ts",
    "probe-agent-failure": "tsx src/cli/probe-agent-failure.ts",
    "probe-budget": "tsx src/cli/probe-budget.ts",
    "probe-append-only": "tsx src/cli/probe-append-only.ts",
    "probe-idempotency": "tsx src/cli/probe-idempotency.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
